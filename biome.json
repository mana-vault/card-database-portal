{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",

  "files": {
    "includes": ["**", "!**/.next", "!**/node_modules", "!**/public"]
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },

  "linter": {
    "enabled": true
  },

  "assist": {
    "enabled": true
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },

  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
